FROM golang:1.21-alpine AS builder
WORKDIR /src
COPY signal/go.mod signal/go.sum ./
RUN go mod download
COPY signal/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /signal-server .

FROM alpine:3.19
RUN apk add --no-cache ca-certificates wget
WORKDIR /app
COPY --from=builder /signal-server /app/signal-server
EXPOSE 8080
ENTRYPOINT ["/app/signal-server"]
