#!/usr/bin/env bash
# =============================================================================
# Any-KVM 部署配置模板
# =============================================================================
#
# 用法：
#   1. 复制本文件到 .github/skills/deploy-test/scripts/env.sh
#      cp deploy/env.example .github/skills/deploy-test/scripts/env.sh
#   2. 按实际情况修改下方变量
#   3. env.sh 已加入 .gitignore，不会被提交到版本控制
#
# 这是整个项目中 **唯一需要填写真实 IP/密码** 的文件。
# 所有脚本和文档均通过引用此处定义的变量来避免硬编码。
# =============================================================================

# ─── 远端信令服务器 ──────────────────────────────────────────────────────────
# 公网 IP 或域名（不含端口号）
REMOTE_HOST="your-server-ip-or-domain"

# SSH 用户名
REMOTE_USER="root"

# SSH 密码（若使用密钥登录，留空并配置好 SSH key 即可）
REMOTE_PASS="your-ssh-password"

# ─── 信令服务器端口 ───────────────────────────────────────────────────────────
SIGNAL_PORT=8080

# ─── TURN 服务器配置（与信令服务器部署在同一台机器时无需修改）─────────────────
TURN_PORT=3478
TURN_USERNAME="kvmuser"
# TURN 密码（建议修改为强密码）
TURN_PASSWORD="change_me_in_production"

# ─── 本机 sudo 密码（build-agent.sh 安装时需要，若无 sudo 可留空）────────────
LOCAL_SUDO_PASS=""

# ─── 工程路径（通常无需修改）────────────────────────────────────────────────
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"
AGENT_BIN="${REPO_ROOT}/agent/target/release/any-kvm-agent"
AGENT_DIR="${REPO_ROOT}/agent"

# ─── 测试用房间 ID ───────────────────────────────────────────────────────────
ROOM_ID="test-room"

# ─── 派生变量（通常无需修改）────────────────────────────────────────────────
SIGNAL_URL="ws://${REMOTE_HOST}:${SIGNAL_PORT}/ws"
TURN_URL="turn:${REMOTE_HOST}:${TURN_PORT}"
